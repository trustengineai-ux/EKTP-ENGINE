# =============================================
# secrets.properties.example
# =============================================
# SALIN file ini menjadi "secrets.properties"
# lalu isi dengan nilai sesungguhnya.
#
# File "secrets.properties" sudah di-exclude di .gitignore
# JANGAN commit secrets.properties ke Git!
# =============================================

VERIHUBS_API_KEY=isi_api_key_verihubs_anda_di_sini
VERIHUBS_BASE_URL=https://api.verihubs.com/v1/

# Keystore (untuk release build)
KEYSTORE_FILE=release.jks
KEYSTORE_PASSWORD=isi_password_keystore
KEY_ALIAS=isi_alias_key
KEY_PASSWORD=isi_password_key
